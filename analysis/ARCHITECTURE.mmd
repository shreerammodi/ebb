graph TD
    subgraph CoreLogic["Core logic (src/lib)"]
        MODEL["Model & Format<br/>lib/model, lib/format"]
        GRID["Grid Engine<br/>lib/grid"]
        HIST["Undo History<br/>lib/history"]
        CMD["Commands & Keymap<br/>lib/commands, lib/keymap"]
        STORE["Round Store (hub)<br/>lib/store"]
        PERSIST["Persistence<br/>lib/persistence (Dexie)"]
        EXPORT["Export & Print<br/>lib/export"]
    end

    subgraph UI["UI (src/app, src/components)"]
        FLOWUI["Flow Editor UI<br/>components/flow, palette"]
        DASH["Dashboard, Search & Trash<br/>components/dashboard, trash; lib/dashboard, lib/search"]
        FOUND["UI Foundation<br/>components/ui, lib/utils, lib/fonts"]
    end

    subgraph Optional["Feature-gated"]
        UPDATE["Update subsystem<br/>lib/update, components/update"]
        GUIDE["Guide & Coach<br/>lib/guide, components/guide"]
    end

    subgraph Desktop["Desktop shell (src-tauri)"]
        TAURI["Tauri shell<br/>lib.rs, menu.rs"]
    end

    GRID --> MODEL
    MODEL -. "cycle: normalize.ts -> migrateRows" .-> GRID
    HIST --> MODEL
    CMD --> MODEL
    CMD --> GRID
    CMD --> STORE
    STORE --> MODEL
    STORE --> GRID
    STORE --> HIST
    STORE --> CMD
    STORE --> UPDATE
    STORE -. "type-only" .-> PERSIST
    PERSIST --> MODEL
    PERSIST --> GRID
    PERSIST --> HIST
    PERSIST --> DASH
    PERSIST -. "type-only: autosave.ts" .-> STORE
    EXPORT --> MODEL
    EXPORT --> GRID
    EXPORT --> PERSIST
    FLOWUI --> STORE
    FLOWUI --> CMD
    FLOWUI --> PERSIST
    FLOWUI --> HIST
    FLOWUI --> EXPORT
    FLOWUI --> UPDATE
    FLOWUI --> GUIDE
    DASH --> MODEL
    DASH --> STORE
    DASH --> PERSIST
    DASH --> EXPORT
    DASH --> GUIDE
    GUIDE --> STORE
    GUIDE --> CMD
    UPDATE --> STORE
    UPDATE -. "dynamic import: adapter.ts" .-> TAURI
    FLOWUI --> FOUND
    DASH --> FOUND
    STORE --> FOUND
