{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Ebb",
    "version": "0.3.1",
    "identifier": "net.smodi.ebb",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1280",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../out"
    },
    "app": {
        "windows": [
            {
                "title": "Ebb",
                "width": 1280,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://github.com https://*.githubusercontent.com"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "signingIdentity": "-"
        }
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/shreerammodi/ebb/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzM0M1RTE2QkYxQThGMDMKUldRRGp4cS9GbDQ4RTZtWWUrem41cXNpNXNwM3Y2VEhXYnVlSzhJMFpQMzBrRVpwdDhTYlhCVVUK"
        }
    }
}
