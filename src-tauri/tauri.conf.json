{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Ebb",
    "version": "0.1.0",
    "identifier": "net.smodi.ebb",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:3000",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../out"
    },
    "app": {
        "windows": [
            {
                "title": "Ebb",
                "width": 1280,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/shreerammodi/ebb/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCQzI1MkNFNTU0QUREMjUKUldRbDNVcFZ6bExDU3lGVTFGWFBBcmg5RS9yeUZrYmU3Z3RoZnZMUFRNck9haWJzUXVMV3VRUTUK"
        }
    }
}
